---
layout: none
---

[
  {%- comment -%}
  Include pages, posts, and documents from each published collection that:
    - have a title
    - are not explicitly search: false
    - are not explicitly published: false
    (Drafts aren’t output in a normal build anyway)
  {%- endcomment -%}

  {%- assign pages = site.pages | concat: site.posts -%}
  {%- assign pages = pages | concat: site.documentation -%}
  {%- assign pages = pages | concat: site.examples -%}
  {%- assign pages = pages | concat: site.installation -%}
  {%- assign pages = pages | where_exp: "page", "page.title" -%}
  {%- assign pages = pages | where_exp: "page", "page.search != false" -%}
  {%- assign pages = pages | where_exp: "page", "page.published != false" -%}

  {%- for page in pages -%}
  {
    "title": {{ page.title | jsonify }},
    "url": {{ page.url | relative_url | jsonify }},
    "content": {{ page.content | strip_html | strip_newlines | jsonify }}
  }{% if forloop.last == false %},{% endif %}
  {%- endfor -%}
]
